@page "/agent18"
@using Markdig
@inject IConfiguration Configuration

<PageTitle>Agent 18 – Tree of Thoughts</PageTitle>

<div class="page-header">
    <h1 class="page-title">🩷 Agent 18 – Tree of Thoughts</h1>
    <p class="page-subtitle">Explores multiple reasoning branches simultaneously, evaluates each path, and selects the most promising solution.</p>
</div>

<div class="alert alert-info mb-4">
    <strong>💡 Tree of Thoughts (ToT):</strong> A prompting strategy that creates a tree-shaped reasoning structure by spawning multiple independent thought branches. Each branch explores a different perspective or approach, and an evaluator agent synthesises the best elements into a final solution.
</div>

<div class="agent-layout layout-4-8">

    <!-- Left: Config Panel -->
    <div>
        <div class="card panel panel-config mb-4">
            <div class="card-header">⚙️ Configuration</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Problem / Question</label>
                    <textarea class="form-control message-input" @bind="message"></textarea>
                </div>
                <div class="mb-2 small text-muted">
                    Spawns 3 branches: <span class="badge badge-primary">Analytical</span> <span class="badge badge-success">Creative</span> <span class="badge badge-primary">Practical</span>
                </div>
                <button class="btn btn-prompting" @onclick="OnSubmit" disabled="@isLoading">
                    @(isLoading ? "Running..." : "🌳 Run Tree of Thoughts")
                </button>
            </div>
        </div>
        @if (logMessages.Count > 0)
        {
            <div class="card panel panel-log mb-4">
                <div class="card-header">📋 Execution Log</div>
                <div class="card-body">
                    <ul class="log-list mb-0">
                        @foreach (var log in logMessages)
                        {
                            <li><code>@log</code></li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>

    <!-- Right: Result Panel -->
    <div>
        @if (isLoading && string.IsNullOrEmpty(branchA))
        {
            <div class="card panel panel-result mb-4">
                <div class="card-header">🌳 Exploring Branches...</div>
                <div class="card-body">
                    <p class="response-pending">
                        <span class="streaming-indicator" aria-label="Processing">
                            <span></span><span></span><span></span>
                        </span>
                        Spawning thought branches...
                    </p>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(branchA))
        {
            <div class="card panel panel-result mb-3">
                <div class="card-header">🔵 Branch A — Mathematical/Analytical</div>
                <div class="card-body">
                    <div class="response-text">@((MarkupString)RenderMarkdown(branchA))</div>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(branchB))
        {
            <div class="card panel panel-result mb-3" style="border-color: var(--color-success);">
                <div class="card-header" style="background-color: var(--color-success); color: white;">🟢 Branch B — Creative/Lateral</div>
                <div class="card-body">
                    <div class="response-text">@((MarkupString)RenderMarkdown(branchB))</div>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(branchC))
        {
            <div class="card panel panel-result mb-3" style="border-color: var(--color-info);">
                <div class="card-header" style="background-color: var(--color-info); color: white;">🔷 Branch C — Practical/Common-Sense</div>
                <div class="card-body">
                    <div class="response-text">@((MarkupString)RenderMarkdown(branchC))</div>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(evaluation))
        {
            <div class="card panel panel-result mb-4" style="border-color: var(--color-warning);">
                <div class="card-header" style="background-color: var(--color-warning); color: #212529;">⚖️ Evaluation &amp; Final Solution</div>
                <div class="card-body">
                    <div class="response-text">@((MarkupString)RenderMarkdown(evaluation))</div>
                </div>
            </div>
        }
    </div>

</div>

@code {
    private string message = "How would you approach building a sustainable city transportation system?";
    private string modelName = "openai/gpt-4.1-nano";
    private string endpoint = "https://openrouter.ai/api/v1";

    private ChatClientAgent agentBranch1 = default!;
    private ChatClientAgent agentBranch2 = default!;
    private ChatClientAgent agentBranch3 = default!;
    private ChatClientAgent agentEvaluator = default!;

    private string branchA = string.Empty;
    private string branchB = string.Empty;
    private string branchC = string.Empty;
    private string evaluation = string.Empty;

    private bool isLoading = false;
    private List<string> logMessages = [];

    private string RenderMarkdown(string value)
        => Markdown.ToHtml(value, new MarkdownPipelineBuilder().UseAdvancedExtensions().Build());

    protected override Task OnInitializedAsync()
    {
        var apiKey = Configuration["OpenRouter:ApiKey"] ?? Configuration["OPEN_ROUTER_API_KEY"] ??
            throw new InvalidOperationException("OpenRouter:ApiKey (or OPEN_ROUTER_API_KEY) is not configured.");
        var openAIClientOptions = new OpenAIClientOptions { Endpoint = new Uri(endpoint) };
        var credential = new ApiKeyCredential(apiKey);

        var chatClient = new ChatClient(modelName, credential, openAIClientOptions);

        agentBranch1 = chatClient.AsAIAgent(
            instructions: "You are Approach A. Explore ONE specific approach to solve the problem. Think step by step from a mathematical/analytical angle. Be concise (3-5 sentences).",
            name: "BranchA");

        agentBranch2 = chatClient.AsAIAgent(
            instructions: "You are Approach B. Explore ONE specific approach to solve the problem. Think step by step from a creative/lateral thinking angle. Be concise (3-5 sentences).",
            name: "BranchB");

        agentBranch3 = chatClient.AsAIAgent(
            instructions: "You are Approach C. Explore ONE specific approach to solve the problem. Think step by step from a practical/common-sense angle. Be concise (3-5 sentences).",
            name: "BranchC");

        agentEvaluator = chatClient.AsAIAgent(
            instructions: "You are a solution evaluator. You will receive three different approaches to a problem. Evaluate which approach is most promising and explain why. Then synthesize the best elements into a Final Solution.",
            name: "Evaluator");

        return base.OnInitializedAsync();
    }

    private async Task OnSubmit()
    {
        isLoading = true;
        branchA = string.Empty;
        branchB = string.Empty;
        branchC = string.Empty;
        evaluation = string.Empty;
        logMessages.Clear();

        try
        {
            logMessages.Add($"🌳 Tree of Thoughts: exploring 3 branches for: \"{message}\"");
            await InvokeAsync(StateHasChanged);

            logMessages.Add("🔍 Exploring Branch A (Mathematical/Analytical)...");
            await InvokeAsync(StateHasChanged);
            branchA = (await agentBranch1.RunAsync(message)).ToString();

            logMessages.Add("🔍 Exploring Branch B (Creative/Lateral)...");
            await InvokeAsync(StateHasChanged);
            branchB = (await agentBranch2.RunAsync(message)).ToString();

            logMessages.Add("🔍 Exploring Branch C (Practical/Common-Sense)...");
            await InvokeAsync(StateHasChanged);
            branchC = (await agentBranch3.RunAsync(message)).ToString();

            logMessages.Add("⚖️ Evaluating all branches and synthesizing Final Solution...");
            await InvokeAsync(StateHasChanged);

            var combinedInput = $"Problem: {message}\n\nApproach A (Mathematical/Analytical):\n{branchA}\n\nApproach B (Creative/Lateral):\n{branchB}\n\nApproach C (Practical/Common-Sense):\n{branchC}";
            evaluation = (await agentEvaluator.RunAsync(combinedInput)).ToString();

            logMessages.Add("✅ Tree of Thoughts complete.");
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}
