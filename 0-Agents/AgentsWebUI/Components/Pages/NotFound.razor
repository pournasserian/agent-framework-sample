@page "/not-found"
@layout MainLayout

<PageTitle>Page Not Found</PageTitle>

<div class="page-header">
    <h1 class="page-title">🔍 Page Not Found</h1>
    <p class="page-subtitle">The page you're looking for doesn't exist or has been moved.</p>
</div>

<div class="card panel mb-4">
    <div class="card-body">
        <div class="alert alert-info mb-4">
            Sorry, we couldn't find what you were looking for. The page may have been moved or the URL may be incorrect.
        </div>
        <a href="/" class="btn btn-primary">← Back to Home</a>
    </div>
</div>
