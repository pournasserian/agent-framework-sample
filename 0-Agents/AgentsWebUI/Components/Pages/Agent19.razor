@page "/agent19"
@using Markdig
@inject IConfiguration Configuration

<PageTitle>Agent 19 – Graph of Thoughts</PageTitle>

<div class="page-header">
    <h1 class="page-title">🩷 Agent 19 – Graph of Thoughts</h1>
    <p class="page-subtitle">Builds a non-linear reasoning graph where thoughts can merge, branch, and reference each other to solve complex problems.</p>
</div>

<div class="alert alert-info mb-4">
    <strong>💡 Graph of Thoughts (GoT):</strong> A prompting strategy that models reasoning as a directed graph. A decomposer breaks the problem into sub-problems (nodes), specialist agents solve each node in parallel, and a synthesizer merges the solutions along graph edges into a final answer.
</div>

<div class="agent-layout layout-4-8">

    <!-- Left: Config Panel -->
    <div>
        <div class="card panel panel-config mb-4">
            <div class="card-header">⚙️ Configuration</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Problem / Question</label>
                    <textarea class="form-control message-input" @bind="message"></textarea>
                </div>
                <div class="mb-2 small text-muted">
                    Graph: <code>Input → Decomposer → Node1, Node2 → Synthesizer → Output</code>
                </div>
                <button class="btn btn-prompting" @onclick="OnSubmit" disabled="@isLoading">
                    @(isLoading ? "Running..." : "🕸️ Run Graph of Thoughts")
                </button>
            </div>
        </div>
        @if (logMessages.Count > 0)
        {
            <div class="card panel panel-log mb-4">
                <div class="card-header">📋 Graph Edges Log</div>
                <div class="card-body">
                    <ul class="log-list mb-0">
                        @foreach (var log in logMessages)
                        {
                            <li><code>@log</code></li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>

    <!-- Right: Result Panel -->
    <div>
        @if (isLoading && string.IsNullOrEmpty(decomposed))
        {
            <div class="card panel panel-result mb-4">
                <div class="card-header">🕸️ Building Graph...</div>
                <div class="card-body">
                    <p class="response-pending">
                        <span class="streaming-indicator" aria-label="Processing">
                            <span></span><span></span><span></span>
                        </span>
                        Decomposing into sub-problems...
                    </p>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(decomposed))
        {
            <div class="card panel panel-result mb-3">
                <div class="card-header">📐 Decomposer — Sub-problems</div>
                <div class="card-body">
                    <div class="response-text">@((MarkupString)RenderMarkdown(decomposed))</div>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(node1Result))
        {
            <div class="card panel panel-result mb-3">
                <div class="card-header">🔷 Node 1 — Sub-problem 1 Solution</div>
                <div class="card-body">
                    <div class="response-text">@((MarkupString)RenderMarkdown(node1Result))</div>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(node2Result))
        {
            <div class="card panel panel-result mb-3" style="border-color: var(--color-success);">
                <div class="card-header" style="background-color: var(--color-success); color: white;">🔶 Node 2 — Sub-problem 2 Solution</div>
                <div class="card-body">
                    <div class="response-text">@((MarkupString)RenderMarkdown(node2Result))</div>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(synthesis))
        {
            <div class="card panel panel-result mb-4" style="border-color: var(--color-warning);">
                <div class="card-header" style="background-color: var(--color-warning); color: #212529;">🔗 Synthesizer — Graph Synthesis</div>
                <div class="card-body">
                    <div class="response-text">@((MarkupString)RenderMarkdown(synthesis))</div>
                </div>
            </div>
        }
    </div>

</div>

@code {
    private string message = "Design an AI system that can both understand medical images and explain its diagnoses to patients.";
    private string modelName = "openai/gpt-4.1-nano";
    private string endpoint = "https://openrouter.ai/api/v1";

    private ChatClientAgent agentDecomposer = default!;
    private ChatClientAgent agentNode1 = default!;
    private ChatClientAgent agentNode2 = default!;
    private ChatClientAgent agentSynthesizer = default!;

    private string decomposed = string.Empty;
    private string node1Result = string.Empty;
    private string node2Result = string.Empty;
    private string synthesis = string.Empty;

    private bool isLoading = false;
    private List<string> logMessages = [];

    private string RenderMarkdown(string value)
        => Markdown.ToHtml(value, new MarkdownPipelineBuilder().UseAdvancedExtensions().Build());

    protected override Task OnInitializedAsync()
    {
        var apiKey = Configuration["OpenRouter:ApiKey"] ?? Configuration["OPEN_ROUTER_API_KEY"] ??
            throw new InvalidOperationException("OpenRouter:ApiKey (or OPEN_ROUTER_API_KEY) is not configured.");
        var openAIClientOptions = new OpenAIClientOptions { Endpoint = new Uri(endpoint) };
        var credential = new ApiKeyCredential(apiKey);

        var chatClient = new ChatClient(modelName, credential, openAIClientOptions);

        agentDecomposer = chatClient.AsAIAgent(
            instructions: "You are a problem decomposer. Break the given problem into exactly 2 independent sub-problems. Label them clearly as 'Sub-problem 1:' and 'Sub-problem 2:'. Be concise.",
            name: "Decomposer");

        agentNode1 = chatClient.AsAIAgent(
            instructions: "You are a specialist solving Sub-problem 1. Solve only the first sub-problem from the input. Be direct and concise (2-3 sentences).",
            name: "Node1");

        agentNode2 = chatClient.AsAIAgent(
            instructions: "You are a specialist solving Sub-problem 2. Solve only the second sub-problem from the input. Be direct and concise (2-3 sentences).",
            name: "Node2");

        agentSynthesizer = chatClient.AsAIAgent(
            instructions: "You are a synthesis expert. You receive solutions to two sub-problems that were part of a larger problem. Merge these solutions into a cohesive final answer, showing how they connect in a reasoning graph. Start with 'Graph synthesis:'.",
            name: "Synthesizer");

        return base.OnInitializedAsync();
    }

    private async Task OnSubmit()
    {
        isLoading = true;
        decomposed = string.Empty;
        node1Result = string.Empty;
        node2Result = string.Empty;
        synthesis = string.Empty;
        logMessages.Clear();

        try
        {
            logMessages.Add("🕸️ Graph of Thoughts: Input → Decomposer → Node1, Node2 → Synthesizer → Output");
            await InvokeAsync(StateHasChanged);

            logMessages.Add("📐 Step 1: Input → Decomposer");
            await InvokeAsync(StateHasChanged);
            decomposed = (await agentDecomposer.RunAsync(message)).ToString();

            logMessages.Add("🔷 Step 2: Decomposer → Node1 (Sub-problem 1)");
            await InvokeAsync(StateHasChanged);
            node1Result = (await agentNode1.RunAsync(decomposed)).ToString();

            logMessages.Add("🔶 Step 3: Decomposer → Node2 (Sub-problem 2)");
            await InvokeAsync(StateHasChanged);
            node2Result = (await agentNode2.RunAsync(decomposed)).ToString();

            logMessages.Add("🔗 Step 4: Node1 + Node2 → Synthesizer → Output");
            await InvokeAsync(StateHasChanged);

            var combinedInput = $"Original problem: {message}\n\nSub-problem 1 solution:\n{node1Result}\n\nSub-problem 2 solution:\n{node2Result}";
            synthesis = (await agentSynthesizer.RunAsync(combinedInput)).ToString();

            logMessages.Add("✅ Graph of Thoughts complete.");
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}
