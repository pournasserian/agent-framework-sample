@page "/agent02"
@inject IConfiguration Configuration

<PageTitle>Agent 02 – Agent with Thread</PageTitle>

<div class="page-header">
    <h1 class="page-title">🧵 Agent 02 – Agent with Thread</h1>
    <p class="page-subtitle">Showcases multi-turn conversations with threads, where the agent maintains context across sequential messages using GetNewThread() for continued interaction.</p>
</div>

<div class="agent-layout layout-4-8">

    <!-- Left: Config Panel -->
    <div>
        <div class="card panel panel-config mb-4">
            <div class="card-header">⚙️ Configuration</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Instructions</label>
                    <InputTextArea @bind-Value="instructions" class="form-control instructions-input"></InputTextArea>
                </div>
                <div class="mb-3">
                    <label class="form-label">First Message</label>
                    <InputTextArea @bind-Value="firstMessage" class="form-control message-input"></InputTextArea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Second Message</label>
                    <InputTextArea @bind-Value="secondMessage" class="form-control message-input"></InputTextArea>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-primary" disabled="@isLoading" @onclick="OnSubmit">
                        @(isLoading ? "Running..." : "🚀 Submit")
                    </button>
                    <button class="btn btn-outline-primary" disabled="@isLoading" @onclick="OnSubmitStream">
                        @(isLoading ? "Streaming..." : "📡 Stream")
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Thread Panel -->
    <div>
        @if (isLoading && string.IsNullOrEmpty(firstResponse))
        {
            <div class="card panel panel-thread mb-4">
                <div class="card-header">🧵 Conversation Thread</div>
                <div class="card-body">
                    <p class="response-pending">
                        <span class="streaming-indicator" aria-label="Processing">
                            <span></span><span></span><span></span>
                        </span>
                        Waiting for response...
                    </p>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(firstResponse))
        {
            <div class="card panel panel-thread mb-4">
                <div class="card-header">
                    🧵 Conversation Thread
                    @if (isLoading)
                    {
                        <span class="streaming-indicator ms-2" aria-label="Streaming">
                            <span></span><span></span><span></span>
                        </span>
                    }
                </div>
                <div class="card-body">
                    <div class="chat-container">
                        <div class="chat-message chat-user">
                            <span class="chat-label">You</span>
                            <div class="chat-bubble">@firstMessage</div>
                        </div>
                        <div class="chat-message chat-assistant">
                            <span class="chat-label">Agent</span>
                            <div class="chat-bubble">
                                <div class="response-text">@firstResponse</div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(secondResponse))
                        {
                            <div class="chat-message chat-user">
                                <span class="chat-label">You</span>
                                <div class="chat-bubble">@secondMessage</div>
                            </div>
                            <div class="chat-message chat-assistant">
                                <span class="chat-label">Agent</span>
                                <div class="chat-bubble">
                                    <div class="response-text">@secondResponse</div>
                                </div>
                            </div>
                        }
                        @if (isLoading && !string.IsNullOrEmpty(firstResponse) && string.IsNullOrEmpty(secondResponse))
                        {
                            <div class="chat-message chat-user">
                                <span class="chat-label">You</span>
                                <div class="chat-bubble">@secondMessage</div>
                            </div>
                            <div class="chat-message chat-assistant chat-typing">
                                <div class="chat-bubble">
                                    <span class="chat-typing-dot"></span>
                                    <span class="chat-typing-dot"></span>
                                    <span class="chat-typing-dot"></span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

</div>

@code {
    private string instructions = "You are good at telling jokes.";
    private string firstMessage = "Tell me a long joke about a pirate. It should be at least two pargraphs.";
    private string secondMessage = "Now add some emojis to the joke and tell it in the voice of a pirate's parrot.";

    private string modelName = "openai/gpt-4.1-nano";
    private string endpoint = "https://openrouter.ai/api/v1";
    private ChatClientAgent agent = default!;

    private string firstResponse = string.Empty;
    private string secondResponse = string.Empty;

    private bool isLoading = false;

    protected override Task OnInitializedAsync()
    {
        var apiKey = Configuration["OpenRouter:ApiKey"] ?? Configuration["OPEN_ROUTER_API_KEY"] ??
            throw new InvalidOperationException("OpenRouter:ApiKey (or OPEN_ROUTER_API_KEY) is not configured.");

        var openAIClientOptions = new OpenAIClientOptions
        {
            Endpoint = new Uri(endpoint),
        };

        var credential = new ApiKeyCredential(apiKey);
        var chatClient = new ChatClient(modelName, credential, openAIClientOptions);
        agent = chatClient.AsAIAgent(instructions: instructions, name: "Joker");

        return base.OnInitializedAsync();
    }

    private async Task OnSubmit()
    {
        firstResponse = string.Empty;
        secondResponse = string.Empty;

        isLoading = true;

        var thread = await agent.CreateSessionAsync();

        var agentResponse = await agent.RunAsync(firstMessage, thread);
        firstResponse = agentResponse.ToString();

        await InvokeAsync(StateHasChanged);

        agentResponse = await agent.RunAsync(secondMessage, thread);
        secondResponse = agentResponse.ToString();

        isLoading = false;
    }

    private async Task OnSubmitStream()
    {
        firstResponse = string.Empty;
        secondResponse = string.Empty;
        isLoading = true;

        var thread = await agent.CreateSessionAsync();

        await foreach (var update in agent.RunStreamingAsync(firstMessage, thread))
        {
            firstResponse += update.ToString();
            await InvokeAsync(StateHasChanged);
        }
        await foreach (var update in agent.RunStreamingAsync(secondMessage, thread))
        {
            secondResponse += update.ToString();
            await InvokeAsync(StateHasChanged);
        }

        isLoading = false;
    }
}
