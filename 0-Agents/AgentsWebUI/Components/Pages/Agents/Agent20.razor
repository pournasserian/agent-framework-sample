@page "/agent20"
@using Markdig
@inject IConfiguration Configuration

<PageTitle>Agent 20 – Program of Thoughts</PageTitle>

<div class="page-header">
    <h1 class="page-title">🩷 Agent 20 – Program of Thoughts (PoT)</h1>
    <p class="page-subtitle">Generates executable pseudocode or step-by-step algorithmic logic to solve problems, separating computation from reasoning.</p>
</div>

<div class="alert alert-info mb-4">
    <strong>💡 Program of Thoughts (PoT):</strong> A prompting strategy that separates reasoning from computation. The model writes a pseudocode program to solve the problem (the "program"), then a separate interpreter agent traces through each step to execute it and derive the final result.
</div>

<div class="agent-layout layout-4-8">

    <!-- Left: Config Panel -->
    <div>
        <div class="card panel panel-config mb-4">
            <div class="card-header">⚙️ Configuration</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Problem / Question</label>
                    <textarea class="form-control message-input" @bind="message"></textarea>
                </div>
                <div class="mb-2 small text-muted">
                    Pipeline: <span class="badge badge-primary">Programmer</span> → <span class="badge badge-success">Interpreter</span>
                </div>
                <button class="btn btn-prompting" @onclick="OnSubmit" disabled="@isLoading">
                    @(isLoading ? "Running..." : "💻 Run Program of Thoughts")
                </button>
            </div>
        </div>
        @if (logMessages.Count > 0)
        {
            <div class="card panel panel-log mb-4">
                <div class="card-header">📋 Log</div>
                <div class="card-body">
                    <ul class="log-list mb-0">
                        @foreach (var log in logMessages)
                        {
                            <li><code>@log</code></li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>

    <!-- Right: Result Panel -->
    <div>
        @if (isLoading && string.IsNullOrEmpty(programOutput))
        {
            <div class="card panel panel-result mb-4">
                <div class="card-header">💻 Generating Program...</div>
                <div class="card-body">
                    <p class="response-pending">
                        <span class="streaming-indicator" aria-label="Processing">
                            <span></span><span></span><span></span>
                        </span>
                        Writing pseudocode...
                    </p>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(programOutput))
        {
            <div class="card panel panel-result mb-3">
                <div class="card-header">📝 Program (Pseudocode)</div>
                <div class="card-body">
                    <pre class="response-text"><code>@programOutput</code></pre>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(executionTrace))
        {
            <div class="card panel panel-result mb-4" style="border-color: var(--color-success);">
                <div class="card-header" style="background-color: var(--color-success); color: white;">▶️ Execution Trace</div>
                <div class="card-body">
                    <div class="response-text">@((MarkupString)RenderMarkdown(executionTrace))</div>
                </div>
            </div>
        }
    </div>

</div>

@code {
    private string message = "Calculate the sum of all even numbers between 1 and 20, then multiply by the count of odd numbers in the same range.";
    private string modelName = "openai/gpt-4.1-nano";
    private string endpoint = "https://openrouter.ai/api/v1";

    private ChatClientAgent agentProgrammer = default!;
    private ChatClientAgent agentInterpreter = default!;

    private string programOutput = string.Empty;
    private string executionTrace = string.Empty;

    private bool isLoading = false;
    private List<string> logMessages = [];

    private string RenderMarkdown(string value)
        => Markdown.ToHtml(value, new MarkdownPipelineBuilder().UseAdvancedExtensions().Build());

    protected override Task OnInitializedAsync()
    {
        var apiKey = Configuration["OpenRouter:ApiKey"] ?? Configuration["OPEN_ROUTER_API_KEY"] ??
            throw new InvalidOperationException("OpenRouter:ApiKey (or OPEN_ROUTER_API_KEY) is not configured.");
        var openAIClientOptions = new OpenAIClientOptions { Endpoint = new Uri(endpoint) };
        var credential = new ApiKeyCredential(apiKey);

        var chatClient = new ChatClient(modelName, credential, openAIClientOptions);

        agentProgrammer = chatClient.AsAIAgent(
            instructions: "You are a computational problem-solver. When given a problem, write a clear pseudocode program to solve it. Use numbered steps, variables, loops and conditionals as needed. Format it as a code block. Do NOT execute it — just write the program.",
            name: "Programmer");

        agentInterpreter = chatClient.AsAIAgent(
            instructions: "You are a program interpreter. You will receive pseudocode and execute it mentally, tracing through each step. Show the variable states and final result. Format: trace each step, show variable values, end with 'Result: [value]'.",
            name: "Interpreter");

        return base.OnInitializedAsync();
    }

    private async Task OnSubmit()
    {
        isLoading = true;
        programOutput = string.Empty;
        executionTrace = string.Empty;
        logMessages.Clear();

        try
        {
            logMessages.Add("💻 Program of Thoughts: generating pseudocode then executing trace");
            await InvokeAsync(StateHasChanged);

            logMessages.Add("📝 Step 1: Generate program (Programmer agent)");
            await InvokeAsync(StateHasChanged);

            var rawProgram = (await agentProgrammer.RunAsync(message)).ToString();

            // Strip markdown code fences if present
            programOutput = rawProgram
                .Replace("```pseudocode", "")
                .Replace("```python", "")
                .Replace("```", "")
                .Trim();

            logMessages.Add("▶️ Step 2: Execute program (Interpreter agent)");
            await InvokeAsync(StateHasChanged);

            executionTrace = (await agentInterpreter.RunAsync($"Pseudocode to execute:\n{rawProgram}")).ToString();

            logMessages.Add("✅ Program of Thoughts complete.");
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}
