@page "/agent22"
@using Markdig
@inject IConfiguration Configuration

<PageTitle>Agent 22 – Reflection</PageTitle>

<div class="page-header">
    <h1 class="page-title">🩷 Agent 22 – Reflection / Self-Critique</h1>
    <p class="page-subtitle">The agent generates an initial response, then critically evaluates its own output for errors, gaps, and improvements.</p>
</div>

<div class="alert alert-info mb-4">
    <strong>💡 Reflection:</strong> A prompting strategy where a second "critic" agent evaluates the initial response from a "responder" agent. The critic identifies errors, missing points, and rates quality — producing a structured self-critique that highlights areas for improvement.
</div>

<div class="agent-layout layout-4-8">

    <!-- Left: Config Panel -->
    <div>
        <div class="card panel panel-config mb-4">
            <div class="card-header">⚙️ Configuration</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Question / Topic</label>
                    <textarea class="form-control message-input" @bind="message"></textarea>
                </div>
                <div class="mb-2 small text-muted">
                    Pipeline: <span class="badge badge-primary">Responder</span> → <span class="badge badge-warning">Critic</span>
                </div>
                <button class="btn" style="background-color:#e83e8c;color:white;" @onclick="OnSubmit" disabled="@isLoading">
                    @(isLoading ? "Running..." : "🪞 Run Reflection")
                </button>
            </div>
        </div>
        @if (logMessages.Count > 0)
        {
            <div class="card panel panel-log mb-4">
                <div class="card-header">📋 Log</div>
                <div class="card-body">
                    <ul class="log-list mb-0">
                        @foreach (var log in logMessages)
                        {
                            <li><code>@log</code></li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>

    <!-- Right: Result Panel -->
    <div>
        @if (isLoading && string.IsNullOrEmpty(initialResponse))
        {
            <div class="card panel panel-result mb-4">
                <div class="card-header">🪞 Generating Initial Response...</div>
                <div class="card-body">
                    <p class="response-pending">
                        <span class="streaming-indicator" aria-label="Processing">
                            <span></span><span></span><span></span>
                        </span>
                        Generating initial response...
                    </p>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(initialResponse))
        {
            <div class="card panel panel-result mb-3">
                <div class="card-header">💬 Initial Response</div>
                <div class="card-body">
                    <div class="response-text">@((MarkupString)RenderMarkdown(initialResponse))</div>
                </div>
            </div>
        }
        @if (isLoading && !string.IsNullOrEmpty(initialResponse) && string.IsNullOrEmpty(critique))
        {
            <div class="card panel panel-result mb-4">
                <div class="card-header">🔍 Applying Self-Critique...</div>
                <div class="card-body">
                    <p class="response-pending">
                        <span class="streaming-indicator" aria-label="Processing">
                            <span></span><span></span><span></span>
                        </span>
                        Critiquing...
                    </p>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(critique))
        {
            <div class="card panel panel-result mb-4" style="border-color: var(--color-danger);">
                <div class="card-header" style="background-color: var(--color-danger); color: white;">🔍 Self-Critique</div>
                <div class="card-body">
                    <div class="response-text">@((MarkupString)RenderMarkdown(critique))</div>
                </div>
            </div>
        }
    </div>

</div>

@code {
    private string message = "Explain the concept of quantum entanglement and its potential applications.";
    private string modelName = "openai/gpt-4.1-nano";
    private string endpoint = "https://openrouter.ai/api/v1";

    private ChatClientAgent agentResponder = default!;
    private ChatClientAgent agentCritic = default!;

    private string initialResponse = string.Empty;
    private string critique = string.Empty;

    private bool isLoading = false;
    private List<string> logMessages = [];

    private string RenderMarkdown(string value)
        => Markdown.ToHtml(value, new MarkdownPipelineBuilder().UseAdvancedExtensions().Build());

    protected override Task OnInitializedAsync()
    {
        var apiKey = Configuration["OpenRouter:ApiKey"] ?? Configuration["OPEN_ROUTER_API_KEY"] ??
            throw new InvalidOperationException("OpenRouter:ApiKey (or OPEN_ROUTER_API_KEY) is not configured.");
        var openAIClientOptions = new OpenAIClientOptions { Endpoint = new Uri(endpoint) };
        var credential = new ApiKeyCredential(apiKey);

        var chatClient = new ChatClient(modelName, credential, openAIClientOptions);

        agentResponder = chatClient.AsAIAgent(
            instructions: "You are a helpful assistant. Answer the question directly and thoroughly. Provide your best initial response.",
            name: "Responder");

        agentCritic = chatClient.AsAIAgent(
            instructions: "You are a rigorous self-critic. You will receive an initial response to a question. Critically evaluate it by:\n1. Identifying potential errors or inaccuracies\n2. Noting any missing important points\n3. Suggesting specific improvements\n4. Rating the response quality (1-10)\n\nFormat your critique with clear sections: 'Errors Found:', 'Missing Points:', 'Suggested Improvements:', 'Quality Rating:'",
            name: "Critic");

        return base.OnInitializedAsync();
    }

    private async Task OnSubmit()
    {
        isLoading = true;
        initialResponse = string.Empty;
        critique = string.Empty;
        logMessages.Clear();

        try
        {
            logMessages.Add("🪞 Reflection: Step 1 — generating initial response...");
            await InvokeAsync(StateHasChanged);

            initialResponse = (await agentResponder.RunAsync(message)).ToString();

            logMessages.Add("🔍 Reflection: Step 2 — applying self-critique...");
            await InvokeAsync(StateHasChanged);

            var criticInput = $"Question: {message}\n\nInitial Response:\n{initialResponse}\n\nPlease critique this response.";
            critique = (await agentCritic.RunAsync(criticInput)).ToString();

            logMessages.Add("✅ Reflection complete.");
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}
